# API Keys
OPENAI_API_KEY=your_openai_api_key
GITHUB_TOKEN=your_github_personal_access_token

# Database
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Email Service
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com

# Other Configuration
SEO_SCORE_THRESHOLD=70 # Minimum acceptable SEO score
AUTO_SCAN_INTERVAL=86400 # In seconds (86400 = 1 day)
MAX_FILES_PER_SCAN=10 # Maximum number of files to scan per repository 